// widgets.ToggleButton2.click(function(e) { selectPU(1); });
// widgets.ToggleButton3.click(function(e) { selectPU(2); });
// widgets.ToggleButton4.click(function(e) { selectPU(3); });

// ════════════════════════════════════════════════════════════════════════
// 7. PLC 输出 → HMI 数值显示（订阅变化推送，无需轮询）
// ════════════════════════════════════════════════════════════════════════

// 横向跟首色窗口间距（mm） → NumericOutput3（GroupBox3 内）
opcua(OPC.diPuWindowIntervalmm).valueChanged(function(e) {
    widgets.NumericOutput3.setValue(e.detail.newValue);
});

// 当前 sImage（色组索引） → NumericOutput2（当前色组+1）
opcua(OPC.diSImage).valueChanged(function(e) {
    widgets.NumericOutput2.setValue(e.detail.newValue);
});
