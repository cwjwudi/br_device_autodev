/**
 * @eventScriptSetId eventscript_0
 * @contentId Content_X67
 */

// ── OPC UA 地址表 ────────────────────────────────────────────────────────
// B&R 全局变量（GlobalMiddle.var）格式：::AsGlobalPV:变量路径
// 若在 HMI 中提示找不到变量，请用 AS OPC UA 浏览器核实节点 ID 后修改此处
const OPC = {
    // ── 输入（HMI → PLC） ──────────────────────────────────────────────
    bRefreshSimData:       '::AsGlobalPV:gstHmi.stInputs.bRefreshSimData',
    bMoveCurveLeft:        '::AsGlobalPV:gstHmi.stInputs.bMoveCurveLeft',
    bMoveCurveRight:       '::AsGlobalPV:gstHmi.stInputs.bMoveCurveRight',
    bMoveLockBoxLeft:      '::AsGlobalPV:gstHmi.stInputs.bMoveLockBoxLeft',
    bMoveLockBoxRight:     '::AsGlobalPV:gstHmi.stInputs.bMoveLockBoxRight',
    bCmdLatchPos:          '::AsGlobalPV:gstHmi.stInputs.bCmdLatchPos',
    bVisMarkIntervalAdd:   '::AsGlobalPV:gstHmi.stInputs.bVisMarkIntervalAdd',
    bVisMarkIntervalMinus: '::AsGlobalPV:gstHmi.stInputs.bVisMarkIntervalMinus',
    diLockBoxWidth:        '::AsGlobalPV:gstHmi.stInputs.diLockBoxWidth',
    usiActivePU:           '::AsGlobalPV:gstMainInface.stToMain.usiActivePU',
    // ── 输出（PLC → HMI 显示） ─────────────────────────────────────────
    diPuWindowIntervalmm:  '::AsGlobalPV:gstHmi.stOutputs.diPuWindowIntervalmm',
    diSImage:              '::AsGlobalPV:gstHmi.stOutputs.diSImage',
};

// ════════════════════════════════════════════════════════════════════════
// 1. 刷新模拟数据
// ════════════════════════════════════════════════════════════════════════
widgets.MomentaryPushButton8.click(function(e) {
    opcua(OPC.bRefreshSimData).setValueBool(true);
});

// ════════════════════════════════════════════════════════════════════════
// 2. 曲线左移 / 右移（按住期间保持 true，松手置 false）
// ════════════════════════════════════════════════════════════════════════
widgets.MomentaryPushButton1.mouseDown(function(e) {
    opcua(OPC.bMoveCurveLeft).setValueBool(true);
});
widgets.MomentaryPushButton1.mouseUp(function(e) {
    opcua(OPC.bMoveCurveLeft).setValueBool(false);
});

widgets.MomentaryPushButton2.mouseDown(function(e) {
    opcua(OPC.bMoveCurveRight).setValueBool(true);
});
widgets.MomentaryPushButton2.mouseUp(function(e) {
    opcua(OPC.bMoveCurveRight).setValueBool(false);
});

// ════════════════════════════════════════════════════════════════════════
// 3. 锁标窗口左移 / 右移
// ════════════════════════════════════════════════════════════════════════
widgets.MomentaryPushButton3.mouseDown(function(e) {
    opcua(OPC.bMoveLockBoxLeft).setValueBool(true);
});
widgets.MomentaryPushButton3.mouseUp(function(e) {
    opcua(OPC.bMoveLockBoxLeft).setValueBool(false);
});

widgets.MomentaryPushButton4.mouseDown(function(e) {
    opcua(OPC.bMoveLockBoxRight).setValueBool(true);
});
widgets.MomentaryPushButton4.mouseUp(function(e) {
    opcua(OPC.bMoveLockBoxRight).setValueBool(false);
});

// ════════════════════════════════════════════════════════════════════════
// 4. 锁标按钮（单次触发）
// ════════════════════════════════════════════════════════════════════════
// widgets.MomentaryPushButton5.click(function(e) {
//     opcua(OPC.bCmdLatchPos).setValueBool(true);
// });

// ════════════════════════════════════════════════════════════════════════
// 5. 横向跟首色：减小 / 增大
// ════════════════════════════════════════════════════════════════════════
widgets.MomentaryPushButton6.mouseDown(function(e) {
    opcua(OPC.bVisMarkIntervalMinus).setValueBool(true);
});
widgets.MomentaryPushButton6.mouseUp(function(e) {
    opcua(OPC.bVisMarkIntervalMinus).setValueBool(false);
});

widgets.MomentaryPushButton7.mouseDown(function(e) {
    opcua(OPC.bVisMarkIntervalAdd).setValueBool(true);
});
widgets.MomentaryPushButton7.mouseUp(function(e) {
    opcua(OPC.bVisMarkIntervalAdd).setValueBool(false);
});

// ════════════════════════════════════════════════════════════════════════
// 6. PU 选择 ToggleButton 互斥（点 PU1 → 其余自动取消选中）
//    并将所选 PU 编号（从 1 开始）写入 PLC
